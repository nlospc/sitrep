{
  "$ref": "#/definitions/Task",
  "definitions": {
    "Task": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "project_ref": {
          "type": "string",
          "format": "uuid"
        },
        "milestone_ref": {
          "type": "string",
          "format": "uuid"
        },
        "owner": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "state": {
          "type": "string",
          "enum": [
            "todo",
            "in_progress",
            "blocked",
            "done"
          ]
        },
        "provenance": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "required": [
        "id",
        "title",
        "project_ref",
        "priority",
        "state",
        "provenance"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
