              "additionalProperties": false
            }
          },
          "required": [
            "id",
            "enqueued_at",
            "kind",
            "payload"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "$ref": "#/definitions/Job/anyOf/0/properties/id"
            },
