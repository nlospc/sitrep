                  "enum": [
                    "morning_digest",
                    "weekly_report"
                  ]
                },
                "scope": {
                  "type": "object",
                  "properties": {
                    "project_ref": {
                      "type": "string",
                      "format": "uuid"
                    }
                  },
                  "additionalProperties": false
                },
                "data": {
                  "type": "object",
                  "properties": {
                    "overnight_changes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "entity_ref": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "entity_kind": {
                            "type": "string",
