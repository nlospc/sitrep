                    "type": "string",
                    "format": "uuid"
                  }
                },
                "is_batch": {
                  "type": "boolean"
                },
                "captured_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "capture_id",
                "raw_text",
                "mentioned_refs",
                "is_batch",
                "captured_at"
