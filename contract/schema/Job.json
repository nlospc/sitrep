                              "project",
                              "milestone",
                              "task"
                            ]
                          },
                          "summary": {
                            "type": "string",
                            "minLength": 1
                          },
                          "proposal_id": {
                            "type": "string",
                            "format": "uuid"
                          }
                        },
                        "required": [
