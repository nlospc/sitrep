                          "entity_kind",
                          "summary",
                          "proposal_id"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "tasks_due_today": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "format": "uuid"
                      }
                    },
                    "pending_proposal_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "new_risk_flags": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "target_ref": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "description": {
                            "type": "string",
                            "minLength": 1
                          },
                          "severity": {
                            "type": "string",
