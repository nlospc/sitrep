{
  "name": "sitrep-workspace",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "prepare": "pnpm --filter @sitrep/contract run build",
    "check": "pnpm --filter @sitrep/contract run build && pnpm -r run typecheck && pnpm run lint",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run",
    "build": "pnpm -r run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
